PORT=3000
NODE_ENV=development

# Dev local:
MONGODB_URI=mongodb://localhost:27017/medagenda
# Produção (MongoDB Atlas):
# MONGODB_URI=mongodb+srv://<user>:<senha>@cluster.mongodb.net/medagenda

# Gere com: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=troque_por_segredo_forte_64_chars_minimo
JWT_REFRESH_SECRET=troque_por_outro_segredo_forte_diferente
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# URL base usada para gerar os links do WhatsApp (confirmar, reagendar, avaliar)
# Produção: domínio real com https (ex: https://app.seudominio.com.br)
APP_URL=http://localhost:5173

# URL(s) do frontend autorizadas pelo CORS
# Múltiplas origens: separar por vírgula
# Ex produção: https://app.seudominio.com.br,https://www.seudominio.com.br
FRONTEND_URL=http://localhost:8080

# ─── Email (SMTP gratuito via nodemailer) ─────────────────────
# Opção 1 — Gmail (grátis, até ~500 e-mails/dia)
#   EMAIL_HOST=smtp.gmail.com
#   EMAIL_PORT=587
#   EMAIL_USER=seuemail@gmail.com
#   EMAIL_PASS=sua_senha_de_app   ← gere em: myaccount.google.com/apppasswords
#
# Opção 2 — Brevo (grátis, até 300 e-mails/dia)
#   EMAIL_HOST=smtp-relay.brevo.com
#   EMAIL_PORT=587
#   EMAIL_USER=seuemail@brevo.com
#   EMAIL_PASS=sua_chave_smtp_brevo
#
# Opção 3 — Ethereal (só para testes locais, não envia de verdade)
#   EMAIL_HOST=smtp.ethereal.email
#   EMAIL_PORT=587
#   EMAIL_USER=gerado_no_ethereal.email
#   EMAIL_PASS=gerado_no_ethereal.email
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=isacmeddev@gmail.com
EMAIL_PASS=pgne xaqa oboe pbra

